// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Agent {
  id                    String             @id @default(cuid())
  did                   String             @unique @map("did")
  agentId               String             @unique @map("agent_id")
  walletAddress         String             @unique @map("wallet_address")
  internalWalletAddress  String?            @unique @map("internal_wallet_address")
  encryptedPrivateKey    String?            @map("encrypted_private_key")
  name                  String             @unique
  status                String             @default("active")
  reputationScore       Float              @default(0) @map("reputation_score")
  metadata              Json               @default("{}")
  createdAt             DateTime           @default(now()) @map("created_at")
  updatedAt             DateTime           @updatedAt @map("updated_at")
  swapTransactions      SwapTransaction[]
  escrows               Escrow[]
  vault                 Vault?

  @@index([status])
  @@index([walletAddress])
  @@index([did])
  @@map("agents")
}

model Vault {
  id                  String   @id @default(cuid())
  agentId             String   @unique @map("agent_id")
  agent               Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  walletAddress       String   @unique @map("wallet_address")
  encryptedPrivateKey String   @map("encrypted_private_key")
  balance             Json     @default("{\"ETH\":0,\"USDC\":0}")
  lockedBalance       Json     @default("{}") @map("locked_balance")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@index([agentId])
  @@index([walletAddress])
  @@map("vaults")
}

model SwapTransaction {
  id            String   @id @default(cuid())
  agentId       String   @map("agent_id")
  agent         Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  walletAddress String   @map("wallet_address")
  tokenIn       String   @map("token_in")
  tokenOut      String   @map("token_out")
  amount        String
  txHash        String?  @map("tx_hash")
  status        String   @default("pending")
  source        String   @default("manual")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([agentId])
  @@index([walletAddress])
  @@index([status])
  @@index([source])
  @@index([createdAt])
  @@map("swap_transactions")
}

enum EscrowStatus {
  LOCKED
  RELEASED
  REFUNDED
}

model Escrow {
  id         String       @id @default(cuid())
  agentId    String       @map("agent_id")
  agent      Agent        @relation(fields: [agentId], references: [id], onDelete: Cascade)
  userId     String?      @map("user_id")
  token      String
  amount     String
  status     EscrowStatus @default(LOCKED)
  txHash     String?      @map("tx_hash")
  storageHash String?     @map("storage_hash")
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")

  @@index([agentId])
  @@index([status])
  @@map("escrows")
}

model TransactionLog {
  id        String   @id @default(cuid())
  agentId   String   @map("agent_id")
  type      String
  txHash    String   @map("tx_hash")
  rootHash  String   @map("root_hash")
  payload   Json
  createdAt DateTime @default(now()) @map("created_at")

  @@index([agentId])
  @@map("transaction_logs")
}
