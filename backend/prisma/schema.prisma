// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Agent {
  id                    String             @id @default(cuid())
  did                   String             @unique @map("did")
  agentId               String             @unique @map("agent_id")
  walletAddress         String             @unique @map("wallet_address")
  internalWalletAddress  String?            @unique @map("internal_wallet_address")
  encryptedPrivateKey    String?            @map("encrypted_private_key")
  name                  String             @unique
  status                String             @default("active")
  reputationScore       Float              @default(0) @map("reputation_score")
  metadata              Json               @default("{}")
  createdAt             DateTime           @default(now()) @map("created_at")
  updatedAt             DateTime           @updatedAt @map("updated_at")
  swapTransactions      SwapTransaction[]
  vault                 Vault?

  @@index([status])
  @@index([walletAddress])
  @@index([did])
  @@map("agents")
}

model Vault {
  id                  String   @id @default(cuid())
  agentId             String   @unique @map("agent_id")
  agent               Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  walletAddress       String   @unique @map("wallet_address")
  encryptedPrivateKey String   @map("encrypted_private_key")
  balance             Float    @default(0)
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@index([agentId])
  @@index([walletAddress])
  @@map("vaults")
}

model SwapTransaction {
  id            String   @id @default(cuid())
  agentId       String   @map("agent_id")
  agent         Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  walletAddress String   @map("wallet_address")
  tokenIn       String   @map("token_in")
  tokenOut      String   @map("token_out")
  amount        String
  txHash        String?  @map("tx_hash")
  status        String   @default("pending")
  source        String   @default("manual")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([agentId])
  @@index([walletAddress])
  @@index([status])
  @@index([source])
  @@index([createdAt])
  @@map("swap_transactions")
}
